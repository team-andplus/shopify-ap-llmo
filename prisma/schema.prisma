// ローカル開発用: SQLite（DB 不要で即動く）。本番は prisma-mysql を使用。
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@map("Session")
}

/// ストアごとの LLMO 設定。アプリホームのフォームで保存。
model LlmoSettings {
  id              String   @id @default(cuid())
  shop            String   @unique
  siteType        String?  // コーポレート / ECのみ / コーポレート兼EC
  storeName       String?
  brandName       String?
  keywords        String?  // 補足キーワード（自由文）
  prohibitions    String?  // 禁止事項（JSON 配列 or 改行区切り）
  llmsTxtBody     String?  // AI が生成した llms.txt 本文（貼り付け用）
  llmsTxtFileUrl  String?  // Files API で作成したファイルの CDN URL（head 参照用）
  llmsTxtFileId   String?  // 更新用の file id（fileUpdate 用）
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("LlmoSettings")
}
