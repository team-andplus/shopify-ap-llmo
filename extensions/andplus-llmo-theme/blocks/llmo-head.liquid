{% comment %}
  AP LLMO: ストアの head に LLM・エージェント向け文書への link を追加する。
  メタフィールドは使わない。固定パス /apps/llmo/... で App Proxy に飛ばし、アプリが DB から CDN URL を参照して 302 する。
{% endcomment %}
{%- if block.settings.enabled -%}
  <link rel="alternate" type="text/plain" href="{{ shop.url }}/apps/llmo/llms.txt" title="LLM-oriented document (llms.txt)" />
  <link rel="alternate" type="text/plain" href="{{ shop.url }}/apps/llmo/llms.full.txt" title="LLM-oriented full summary (llms.full.txt)" />
  <link rel="alternate" type="text/markdown" href="{{ shop.url }}/apps/llmo/docs/ai/README.md" title="LLMO docs: README" />
{%- endif -%}
{% schema %}
{
  "name": "LLMO head",
  "target": "head",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "LLMO リンクを head に追加する",
      "default": true
    }
  ]
}
{% endschema %}
