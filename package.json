{
  "name": "shopify-ap-llmo",
  "private": true,
  "scripts": {
    "build": "react-router build",
    "build:prod": "npm run setup:prod && SHOPIFY_APP_URL=https://apps.andplus.tech/andplus-apps/shopify-ap-llmo/ react-router build",
    "build:prod-url": "SHOPIFY_APP_URL=https://apps.andplus.tech/andplus-apps/shopify-ap-llmo/ react-router build",
    "dev": "shopify app dev",
    "dev:localhost": "shopify app dev --use-localhost",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "DOTENV_CONFIG_PATH=../common/shopify-ap-llmo.env node -r dotenv/config ./node_modules/@react-router/serve/dist/cli.js ./build/server/index.js",
    "setup": "prisma generate && prisma migrate deploy",
    "setup:prod": "prisma generate --schema=prisma-mysql/schema.prisma && sh scripts/migrate-mysql.sh",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "typecheck": "react-router typegen && tsc --noEmit"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@react-router/dev": "^7.12.0",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^8.0.0",
    "dotenv": "^16.4.5",
    "isbot": "^5.1.31",
    "prisma": "^6.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.12.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@shopify/api-codegen-preset": "^1.2.0",
    "@shopify/polaris-types": "^1.0.1",
    "@types/node": "^22.18.8",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "typescript": "^5.9.3",
    "vite": "^6.3.6"
  },
  "workspaces": [
    "extensions/*"
  ],
  "author": "mmochi"
}
